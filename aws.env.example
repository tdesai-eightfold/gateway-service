# AWS deployment with Route 53 zone "container-resolver-dns"
# Resolves {hash}.workspace.internal.container-resolver-dns
NGINX_PROVIDER=aws

# Optional: override workspace domain (default for aws: workspace.internal.container-resolver-dns)
# NGINX_WORKSPACE_DOMAIN=workspace.internal.container-resolver-dns

# Optional: set resolver if needed (default uses system resolver via 127.0.0.53)
# NGINX_RESOLVER=10.0.0.2
